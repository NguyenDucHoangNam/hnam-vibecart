# =========================================================================
# VibeCart Project Root GitIgnore Configuration
# =========================================================================

# AI Agent Configuration
.agents/

# -------------------------------------------------------------------------
# System & IDE Files
# -------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# Eclipse / STS
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# -------------------------------------------------------------------------
# Environment Variables & Secrets (CRITICAL: Never commit these!)
# -------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup
*.pem
*.key
*.cert
secrets.properties

# Sub-directory specific envs
backend/.env
frontend/.env*

# -------------------------------------------------------------------------
# Dependencies & Build Outputs
# -------------------------------------------------------------------------
# Node.js / Frontend
**/node_modules/
**/.pnp
.pnp.*
**/.yarn/
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# Next.js & Build outputs
**/.next/
**/out/
**/build/
**/dist/
frontend/tsconfig.tsbuildinfo

# Java / Maven / Spring Boot
**/target/
**/.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
backend/logs/

# Testing Coverage
**/coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -------------------------------------------------------------------------
# Temporary & Cache Files
# -------------------------------------------------------------------------
.vercel
.turbo
.cache/
.npm
.eslintcache
