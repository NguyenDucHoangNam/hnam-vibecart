# ===================================================================
# VibeCart Backend - Environment Variables Template (.env.example)
# Instructions: Copy this file to '.env' and fill in your actual credentials.
# ===================================================================

# 1. Database Connection Configurations (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5435/vibecart?options=-c%20timezone=UTC
DB_USERNAME=your-database-username
DB_PASSWORD=your-database-password

# Docker Compose specific (used by compose.yaml for container init)
DB_USER=your-database-username
DB_NAME=vibecart

# 2. MongoDB Configuration
MONGODB_URI=mongodb://username:password@localhost:27018/vibecart_db?authSource=admin

# Docker Compose specific (used by compose.yaml for container init)
MONGO_USER=your-mongo-username
MONGO_PASSWORD=your-mongo-password
MONGO_DB=vibecart_db

# 3. JWT Security Configuration
JWT_SECRET=your-jwt-secret-base64-encoded
JWT_EXPIRATION_MS=3600000

# 4. Email Server Configuration (SMTP - Gmail)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
FRONTEND_URL=http://localhost:3000

# 5. PayOS Gateways Configuration
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
PAYOS_RETURN_URL=http://localhost:3000/payment/success
PAYOS_CANCEL_URL=http://localhost:3000/payment/cancel

# 6. Storage Configuration (MinIO / AWS S3)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET_NAME=vibecart-media
STORAGE_ACCESS_KEY=your-storage-access-key
STORAGE_SECRET_KEY=your-storage-secret-key
STORAGE_REGION=us-east-1

# 7. Elasticsearch Configuration
ELASTIC_PASSWORD=your-elastic-password

# 8. Database Initialization Seeding (Sample Accounts)
SEEDING_ENABLED=true
SEED_USER_USERNAME=user_demo
SEED_USER_PASSWORD=12345678
SEED_USER_EMAIL=shopper_demo@vibecart.com
SEED_USER_FULLNAME=Shopper Demo

SEED_CREATOR_USERNAME=creator_demo
SEED_CREATOR_PASSWORD=12345678
SEED_CREATOR_EMAIL=creator_demo@vibecart.com
SEED_CREATOR_FULLNAME=Creator Demo

SEED_ADMIN_USERNAME=admin_demo
SEED_ADMIN_PASSWORD=12345678
SEED_ADMIN_EMAIL=admin_demo@vibecart.com
SEED_ADMIN_FULLNAME=Admin Demo

# 9. Kafka Message Queue Configuration
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092
